# VAULT — Step One configuration
# Copy to .env and fill in. Secrets NEVER leave this project's .env.

# ── Vault ────────────────────────────────────────────────────────────────
# Absolute path to the Obsidian vault to index/visualize
VAULT_PATH=/home/brice/Obsidian_Vaults/Sabrina

# ── Hermes API (FastAPI sidecar) ─────────────────────────────────────────
HERMES_API_HOST=127.0.0.1
HERMES_API_PORT=8100
# Local bearer token for REST/WS auth (M4.4). Generate: openssl rand -hex 24
HERMES_API_TOKEN=

# ── Obsidian write layer (M4.2) ──────────────────────────────────────────
# obsidian-local-rest-api plugin (HTTP port; cyanheads server wraps this)
OBSIDIAN_REST_URL=http://127.0.0.1:27123
OBSIDIAN_REST_API_KEY=

# ── Model workers (M5) — two independent single-GPU llama.cpp Vulkan ─────
# NEVER tensor-split across cards (PRD §3.1)
WORKER_R9700_URL=http://127.0.0.1:8081/v1
WORKER_7900XTX_URL=http://127.0.0.1:8082/v1

# ── Paid-API fallback (M5.3) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Plane (M6.2) ─────────────────────────────────────────────────────────
PLANE_API_URL=
PLANE_API_TOKEN=
PLANE_WORKSPACE_SLUG=
PLANE_PROJECT_ID=

# ── Grafana embed (M6.3) ────────────────────────────────────────────────
GRAFANA_EMBED_URL=
